[
  {
    "label": "CMake configure",
    "command": "cmake",
    "args": [
      "-B", "build", "-S", ".",
      "-DMPI_C_HEADER_DIR=C:/Program Files (x86)/Microsoft SDKs/MPI/Include",
      "-DMPI_CXX_HEADER_DIR=C:/Program Files (x86)/Microsoft SDKs/MPI/Include",
      "-DMPI_C_LIB_NAMES=msmpi",
      "-DMPI_CXX_LIB_NAMES=msmpi",
      "-DMPI_msmpi_LIBRARY=C:/Program Files (x86)/Microsoft SDKs/MPI/Lib/x64/msmpi.lib"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "CMake configure (SSL)",
    "command": "cmake",
    "args": [
      "-B", "build", "-S", ".", "-DUSE_SSL=ON",
      "-DMPI_C_HEADER_DIR=C:/Program Files (x86)/Microsoft SDKs/MPI/Include",
      "-DMPI_CXX_HEADER_DIR=C:/Program Files (x86)/Microsoft SDKs/MPI/Include",
      "-DMPI_C_LIB_NAMES=msmpi",
      "-DMPI_CXX_LIB_NAMES=msmpi",
      "-DMPI_msmpi_LIBRARY=C:/Program Files (x86)/Microsoft SDKs/MPI/Lib/x64/msmpi.lib"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "Build",
    "command": "cmake",
    "args": ["--build", "build", "--parallel", "4"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "Build (verbose)",
    "command": "cmake",
    "args": ["--build", "build", "--parallel", "4", "--verbose"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "CMake + Build",
    "command": "powershell",
    "args": ["-Command", "cmake -B build -S . && cmake --build build --parallel 4"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "Run: n=1 m=1 (3 procesy)",
    "command": "mpiexec",
    "args": ["-n", "3", "build\\Debug\\UPP-SP2.exe", "-n", "1", "-m", "1"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "Run: n=2 m=2 (7 procesů)",
    "command": "mpiexec",
    "args": ["-n", "7", "build\\Debug\\UPP-SP2.exe", "-n", "2", "-m", "2"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "Run: n=3 m=2 (10 procesů)",
    "command": "mpiexec",
    "args": ["-n", "10", "build\\Debug\\UPP-SP2.exe", "-n", "3", "-m", "2"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "Clean build",
    "command": "powershell",
    "args": ["-Command", "Remove-Item -Recurse -Force build -ErrorAction SilentlyContinue"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  }
]
